---
const { title, pubDate, description, author, tags, link } = Astro.props;
---

<a href=`${link}` target="_blank" class="text-text pt-10">
  <div
    class="bg-[#141510] rounded-[18px] transition-all hover:scale-110 active:scale-90 ease-in-out h-[150px] w-[379px] "
  >
    <div class="p-[25px] font-[550]">
        <span class="text-[#4EC2A7] text-[20px]">{title}</span>
        <p class="text-[15px] my-4">{description}</p>
        <div class="text-[14px]">{pubDate}</div>
    </div>
  </div>
</a>
