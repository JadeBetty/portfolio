---

<header
  class="hidden sm:flex max-w-[75rem] text-text m-auto pt-10"
  id="headers"
>
  <a href="#" class="text-3xl">JadeBetty</a>
  <div
    class="underline mt-1 ml-[50rem] text-lg transition-all hover:scale-110 active:scale-90 ease-in-out"
  >
    <a href="/" class="hover:transition hover:ease-out">Home</a>
  </div>
  <div
    class="mt-1 ml-10 text-lg transition-all hover:scale-110 active:scale-90 ease-in-out hover:underline"
  >
    <a href="/blogs">Blogs</a>
  </div>
  <div
    class="mt-1 ml-10 text-lg transition-all hover:scale-110 active:scale-90 ease-in-out hover:underline"
  >
    <a href="https://github.com/JadeBetty/portfolio" target="_blank">Github</a>
  </div>
</header>

<header
  class="flex sm:hidden w-[200px] text-text m-auto pt-5"
  id="mobile-headers"
>
  <div>
    <a href="/" class="flex text-2xl items-center gap-3">
      <img src="/images/favicon.png" class="w-[50px] rounded-full" />
      JadeBetty
    </a>

    <div class="flex mt-1 text-base">
      <a
        href="/"
        class="underline hover:scale-110 active:scale-90 transition-all duration-300 ease-in-out"
        >Home</a
      >
      <a
        href="/blogs"
        class="ml-5 hover:underline hover:scale-110 active:scale-90 transition-all duration-300 ease-in-out"
        >Blogs</a
      >
      <a
        href="https://github.com/JadeBetty/portfolio"
        target="_blank"
        class="ml-5 hover:underline hover:scale-110 active:scale-90 transition-all duration-300 ease-in-out"
        >Github</a
      >
    </div>
  </div>
</header>
