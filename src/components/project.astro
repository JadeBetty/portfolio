---
export interface Props {
  owner: string;
  repo: string;
  description: string;
  language: string;
}
const { owner, repo, description, language } = Astro.props;
---

<a href=`https://github.com/${owner}/${repo}` target="_blank" class="text-text">
  <div
    class="bg-[#141510] rounded-[18px] transition-all hover:scale-110 active:scale-90 ease-in-out h-[150px] w-[379px]"
  >
    <div class="p-[25px] font-[550]">
        <span class="text-[#4EC2A7] text-[20px]">{repo}</span>
        <p class="text-[15px] my-4">{description}</p>
        <div class="text-[14px]">{language}</div>
    </div>
  </div>
</a>
